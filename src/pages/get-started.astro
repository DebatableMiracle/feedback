---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const page = await getEntry("pages", "get-started");
if (!page) {
	return Astro.redirect("/404");
}
const { Content } = await page.render();
---

<BaseLayout title={page.data.title} description={page.data.description ?? page.data.title}>
	<article class="max-w-[65ch] mx-auto prose font-serif py-12 px-4">
		<h1 class="font-bold text-3xl mb-8 font-sans">{page.data.title}</h1>
		<Content />
	</article>
</BaseLayout>
