---
import { type CollectionEntry, getCollection } from "astro:content";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import FormattedDate from "../../../components/FormattedDate.astro";

export async function getStaticPaths() {
	const notes = await getCollection("library-notes");
	return notes.map((note) => ({
		params: { slug: note.slug },
		props: note,
	}));
}

type Props = CollectionEntry<"library-notes">;

const note = Astro.props;
const { Content } = await note.render();
---

<BaseLayout title={note.data.title} description={note.data.description}>
	<article class="max-w-[65ch] mx-auto">
		<div class="mb-8">
			<a href="/library/notes" class="text-sm font-mono text-secondary hover:text-accent transition-colors">← Notes</a>
		</div>
		<header class="mb-12">
			<h1 class="text-4xl font-serif font-bold mb-4 leading-tight">
				{note.data.title}
			</h1>
			<div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mt-6 text-sm font-mono text-secondary">
				{
					note.data.tags && (
						<div class="flex flex-wrap gap-2">
							{note.data.tags.map((tag) => (
								<a href={`/tags/${tag}`} class="hover:text-accent">
									#{tag}
								</a>
							))}
						</div>
					)
				}
				<FormattedDate date={note.data.date} class="shrink-0" />
			</div>
		</header>
		<div class="prose prose-lg font-serif mx-auto">
			<Content />
		</div>
	</article>
</BaseLayout>
