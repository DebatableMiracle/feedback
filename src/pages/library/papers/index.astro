---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const papers = (await getCollection("papers")).filter((p) => p.data.published);

// Umbrella tags duplicate `topic` — only specific keywords become graph nodes
const UMBRELLA_TAGS = new Set(["rl", "imitation-learning", "model-based-rl", "model-free"]);

const keywordTags = [
	...new Set(
		papers.flatMap((p) =>
			(p.data.tags ?? []).filter((t) => !UMBRELLA_TAGS.has(t))
		)
	),
].sort();

const topics = [...new Set(papers.map((p) => p.data.topic))];

const nodes = [
	...topics.map((topic) => ({
		id: `topic:${topic}`,
		label: topic,
		type: "topic",
	})),
	...keywordTags.map((tag) => ({
		id: `keyword:${tag}`,
		label: tag,
		type: "keyword",
	})),
	...papers.map((p) => ({
		id: p.slug,
		label: p.data.title,
		authors: p.data.authors,
		year: p.data.year,
		topic: p.data.topic,
		keywords: (p.data.tags ?? []).filter((t) => !UMBRELLA_TAGS.has(t)),
		tldr: p.data.tldr,
		url: `/library/papers/${p.slug}/`,
		read: p.data.read,
		type: "paper",
	})),
];

// Edges: paper→topic, paper→keyword (no paper↔paper)
const links: { source: string; target: string }[] = [];

papers.forEach((p) => {
	links.push({ source: p.slug, target: `topic:${p.data.topic}` });
	(p.data.tags ?? [])
		.filter((t) => !UMBRELLA_TAGS.has(t))
		.forEach((tag) => {
			links.push({ source: p.slug, target: `keyword:${tag}` });
		});
});

const graphData = JSON.stringify({ nodes, links });
---

<BaseLayout title="Papers — Graph" description="Papers I've read, as a graph.">
	<div class="mb-8 flex justify-between items-center">
		<a href="/library" class="text-sm font-mono text-secondary hover:text-accent transition-colors">← Library</a>
		<a href="/library/papers/list" class="text-sm font-mono text-secondary hover:text-accent transition-colors">List view →</a>
	</div>
	<div class="mb-6">
		<h1 class="text-3xl font-serif font-bold mb-1">Papers</h1>
		<p class="text-secondary text-sm font-mono">{papers.length} papers · scroll to zoom · drag background to pan</p>
	</div>

	<div id="graph-wrap" class="relative border border-border rounded-sm" style="width: 100vw; position: relative; left: 50%; transform: translateX(-50%); max-width: 860px;">
		<svg id="graph" style="width: 100%; height: min(75vh, 720px); display: block; background: #f9f9f9; cursor: grab;"></svg>
		<button id="fit-btn" type="button" class="absolute top-3 right-3 text-xs font-mono text-secondary hover:text-accent transition-colors border border-border bg-bg px-2 py-1 rounded-sm">
			fit view
		</button>
	</div>

	<div id="tooltip" style="
		position: fixed;
		background: #f9f9f9;
		border: 1px solid #e5e5e5;
		padding: 10px 14px;
		max-width: 260px;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.1s;
		z-index: 1000;
		font-family: Inter, system-ui, sans-serif;
	"></div>

	<script type="application/json" id="graph-data" set:html={graphData}></script>
</BaseLayout>

<script is:inline src="https://cdn.jsdelivr.net/npm/d3@7/dist/d3.min.js"></script>
<script is:inline>
(function () {
	const raw = document.getElementById("graph-data").textContent;
	const data = JSON.parse(raw);
	const tooltip = document.getElementById("tooltip");

	const container = document.getElementById("graph");
	const width = container.clientWidth || 800;
	const height = container.clientHeight || 720;

	const svg = d3.select("#graph")
		.attr("viewBox", `0 0 ${width} ${height}`)
		.attr("preserveAspectRatio", "xMidYMid meet");

	const zoomLayer = svg.append("g");

	// background rect for panning
	zoomLayer.append("rect")
		.attr("width", width * 4)
		.attr("height", height * 4)
		.attr("x", -width * 1.5)
		.attr("y", -height * 1.5)
		.attr("fill", "transparent");

	const linkG = zoomLayer.append("g");
	const nodeG = zoomLayer.append("g");

	const nodeRadius = (d) => {
		if (d.type === "topic") return 48;
		if (d.type === "keyword") return 28;
		return 14;
	};

	const simulation = d3.forceSimulation(data.nodes)
		.force("link", d3.forceLink(data.links).id((d) => d.id).distance((d) => {
			const target = typeof d.target === "object" ? d.target : data.nodes.find((n) => n.id === d.target);
			return target?.type === "keyword" ? 55 : 80;
		}).strength(0.35))
		.force("charge", d3.forceManyBody().strength((d) => {
			if (d.type === "topic") return -400;
			if (d.type === "keyword") return -120;
			return -80;
		}))
		.force("center", d3.forceCenter(width / 2, height / 2))
		.force("collision", d3.forceCollide().radius(nodeRadius));

	const zoom = d3.zoom()
		.scaleExtent([0.15, 3])
		.on("zoom", (event) => {
			zoomLayer.attr("transform", event.transform);
		})
		.filter((event) => {
			if (event.type === "wheel") return true;
			return event.target.tagName === "rect";
		});

	svg.call(zoom).on("dblclick.zoom", null);

	function fitToView(duration = 600) {
		const bounds = zoomLayer.node().getBBox();
		if (!bounds.width || !bounds.height) return;
		const pad = 48;
		const scale = Math.min(
			0.9,
			(width - pad * 2) / bounds.width,
			(height - pad * 2) / bounds.height
		);
		const midX = bounds.x + bounds.width / 2;
		const midY = bounds.y + bounds.height / 2;
		const transform = d3.zoomIdentity
			.translate(width / 2, height / 2)
			.scale(scale)
			.translate(-midX, -midY);
		svg.transition().duration(duration).call(zoom.transform, transform);
	}

	document.getElementById("fit-btn").addEventListener("click", () => fitToView(400));

	const link = linkG.selectAll("line")
		.data(data.links)
		.join("line")
		.attr("stroke", (d) => {
			const target = typeof d.target === "object" ? d.target : null;
			return target?.type === "keyword" ? "#ebebeb" : "#e0e0e0";
		})
		.attr("stroke-width", (d) => {
			const target = typeof d.target === "object" ? d.target : null;
			return target?.type === "keyword" ? 0.75 : 1;
		});

	const paperColor = (d) => d.read ? "#666666" : "#d0d0d0";

	const node = nodeG.selectAll("g")
		.data(data.nodes)
		.join("g")
		.style("cursor", (d) => d.type === "paper" ? "pointer" : "grab")
		.call(
			d3.drag()
				.on("start", (event, d) => {
					event.sourceEvent.stopPropagation();
					if (!event.active) simulation.alphaTarget(0.3).restart();
					d.fx = d.x; d.fy = d.y;
					svg.style("cursor", "grabbing");
				})
				.on("drag", (event, d) => {
					const [x, y] = d3.pointer(event, zoomLayer.node());
					d.fx = x; d.fy = y;
				})
				.on("end", (event, d) => {
					if (!event.active) simulation.alphaTarget(0);
					d.fx = null; d.fy = null;
					svg.style("cursor", "grab");
				})
		);

	node.append("circle")
		.attr("r", (d) => {
			if (d.type === "topic") return 10;
			if (d.type === "keyword") return 4;
			return 5;
		})
		.attr("fill", (d) => {
			if (d.type === "topic") return "#111111";
			if (d.type === "keyword") return "#f9f9f9";
			return paperColor(d);
		})
		.attr("stroke", (d) => d.type === "keyword" ? "#cccccc" : "none")
		.attr("stroke-width", (d) => d.type === "keyword" ? 1.5 : 0)
		.on("mouseover", function (event, d) {
			if (d.type === "paper") {
				d3.select(this).attr("fill", "#111111");
				tooltip.style.opacity = "1";
				tooltip.innerHTML = `
					<div style="font-weight:600;color:#111;margin-bottom:3px;font-size:13px;line-height:1.4">${d.label}</div>
					<div style="color:#666;font-size:11px;font-family:'JetBrains Mono',monospace;margin-bottom:6px">${d.authors} · ${d.year}</div>
					<div style="color:#666;font-size:12px;line-height:1.5">${d.tldr}</div>
				`;
			} else if (d.type === "keyword") {
				d3.select(this).attr("stroke", "#111111");
				tooltip.style.opacity = "1";
				tooltip.innerHTML = `<div style="color:#666;font-size:11px;font-family:'JetBrains Mono',monospace">#${d.label}</div>`;
			}
		})
		.on("mousemove", (event) => {
			tooltip.style.left = (event.clientX + 14) + "px";
			tooltip.style.top = (event.clientY - 14) + "px";
		})
		.on("mouseout", function (event, d) {
			if (d.type === "paper") {
				d3.select(this).attr("fill", paperColor(d));
				tooltip.style.opacity = "0";
			} else if (d.type === "keyword") {
				d3.select(this).attr("stroke", "#cccccc");
				tooltip.style.opacity = "0";
			}
		})
		.on("click", (event, d) => {
			if (d.type === "paper") window.location.href = d.url;
		});

	node.filter((d) => d.type === "topic")
		.append("text")
		.text((d) => d.label.toUpperCase())
		.attr("x", 14)
		.attr("dy", "0.35em")
		.attr("font-family", "'JetBrains Mono', monospace")
		.attr("font-size", "10px")
		.attr("font-weight", "600")
		.attr("letter-spacing", "0.08em")
		.attr("fill", "#111111");

	node.filter((d) => d.type === "keyword")
		.append("text")
		.text((d) => d.label)
		.attr("x", 8)
		.attr("dy", "0.35em")
		.attr("font-family", "'JetBrains Mono', monospace")
		.attr("font-size", "9px")
		.attr("fill", "#999999");

	let fitted = false;
	simulation.on("tick", () => {
		link
			.attr("x1", (d) => d.source.x)
			.attr("y1", (d) => d.source.y)
			.attr("x2", (d) => d.target.x)
			.attr("y2", (d) => d.target.y);
		node.attr("transform", (d) => `translate(${d.x},${d.y})`);
	});

	simulation.on("end", () => {
		if (!fitted) {
			fitted = true;
			fitToView(0);
		}
	});
})();
</script>
